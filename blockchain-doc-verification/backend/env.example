## Backend server
PORT=8080
CORS_ORIGIN=*

## Chain config
## For local hardhat node: http://127.0.0.1:8545
RPC_URL=http://127.0.0.1:8545

## IMPORTANT: use a funded account private key for the chosen network.
## For hardhat node, you can use the first default account key (local only):
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

## Address of deployed DocumentRegistry (set after deploy)
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

## IPFS provider (choose one)
# PINATA_JWT=YOUR_PINATA_JWT
# WEB3_STORAGE_TOKEN=YOUR_WEB3_STORAGE_TOKEN

## Dev-only: allow running without IPFS credentials
# IPFS_DISABLED=true

## Optional gateway base (must end with /ipfs/)
IPFS_GATEWAY_BASE_URL=https://ipfs.io/ipfs/


RPC_URL=http://127.0.0.1:8545
