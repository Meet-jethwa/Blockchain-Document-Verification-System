# Copy this file to .env and fill values.
# NEVER commit your real .env or private key.

# Your wallet private key used to deploy contracts (test wallet only).
# You can paste with or without the 0x prefix.
DEPLOYER_PRIVATE_KEY=

# RPC URLs (get from Alchemy/Infura/QuickNode/etc)
SEPOLIA_RPC_URL=
AMOY_RPC_URL=
